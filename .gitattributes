# Normalise line endings in the repo to LF; check out native on each platform.
* text=auto
*.cs text
*.csproj text
*.props text
*.targets text
*.slnx text
*.yml text
*.md text

# Binary fixtures (e.g. sample .ser frames) must never be munged.
*.ser binary
*.png binary
*.tif binary
*.tiff binary
*.ttf binary
*.ico binary
